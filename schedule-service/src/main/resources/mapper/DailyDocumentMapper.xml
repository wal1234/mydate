<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.scheduleservice.mapper.DailyDocumentMapper">

    <resultMap id="BaseResultMap" type="com.example.scheduleservice.entity.DailyDocument">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="doc_date" property="docDate"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="content_type" property="contentType"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, doc_date, title, content, content_type, created_at, updated_at, deleted
    </sql>

    <select id="selectByDocDate" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM daily_document
        WHERE deleted = 0 AND doc_date = #{docDate}
        LIMIT 1
    </select>

    <select id="selectByDateRange" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM daily_document
        WHERE deleted = 0
          AND doc_date &gt;= #{from}
          AND doc_date &lt;= #{to}
        ORDER BY doc_date
    </select>

    <select id="countByDateRange" resultType="long">
        SELECT COUNT(*)
        FROM daily_document
        WHERE deleted = 0
          AND doc_date &gt;= #{from}
          AND doc_date &lt;= #{to}
    </select>

    <select id="selectByDateRangePaged" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM daily_document
        WHERE deleted = 0
          AND doc_date &gt;= #{from}
          AND doc_date &lt;= #{to}
        ORDER BY doc_date
        LIMIT #{limit} OFFSET #{offset}
    </select>
</mapper>
