<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.scheduleservice.mapper.ScheduleEventMapper">

    <resultMap id="BaseResultMap" type="com.example.scheduleservice.entity.ScheduleEvent">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="is_all_day" property="isAllDay"/>
        <result column="color" property="color"/>
        <result column="repeat_rule" property="repeatRule"/>
        <result column="repeat_until" property="repeatUntil"/>
        <result column="reminder_minutes" property="reminderMinutes"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, title, description, start_time, end_time, is_all_day, color,
        repeat_rule, repeat_until, reminder_minutes, created_at, updated_at, deleted
    </sql>

    <!-- 按时间范围查询：事件与 [start, end] 有交集 -->
    <select id="selectByTimeRange" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM schedule_event
        WHERE deleted = 0
          AND start_time &lt; #{end}
          AND end_time &gt; #{start}
        ORDER BY start_time
    </select>

    <!-- 按时间范围总数，用于分页 -->
    <select id="countByTimeRange" resultType="long">
        SELECT COUNT(*)
        FROM schedule_event
        WHERE deleted = 0
          AND start_time &lt; #{end}
          AND end_time &gt; #{start}
    </select>

    <!-- 按时间范围分页查询 -->
    <select id="selectByTimeRangePaged" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM schedule_event
        WHERE deleted = 0
          AND start_time &lt; #{end}
          AND end_time &gt; #{start}
        ORDER BY start_time
        LIMIT #{limit} OFFSET #{offset}
    </select>
</mapper>
